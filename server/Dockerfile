# Use OpenJDK 17 (matches your java.version in pom.xml)
FROM eclipse-temurin:17-jdk-alpine

# Set the working directory
WORKDIR /app

# Copy the maven wrapper and pom file first to cache dependencies
COPY .mvn/ .mvn
COPY mvnw pom.xml ./

# Fix permissions for the maven wrapper
RUN chmod +x mvnw

# Download dependencies (this makes future builds faster)
RUN ./mvnw dependency:go-offline

# Copy the actual source code
COPY src ./src

# Build the application into a JAR file
RUN ./mvnw clean package -DskipTests

# Run the specific JAR file generated by your pom.xml
ENTRYPOINT ["java","-jar","target/server-0.0.1-SNAPSHOT.jar"]